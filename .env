# Glob API URL
VITE_GLOB_API_URL=/api

VITE_APP_API_BASE_URL=http://127.0.0.1:3002/

# Whether long replies are supported, which may result in higher API fees
VITE_GLOB_OPEN_LONG_REPLY=false

# Default chat model shared by frontend display and backend fallback
VITE_DEFAULT_GPT_MODEL=gemini-3-flash-preview

# Available chat models, separated by commas
VITE_AVAILABLE_GPT_MODELS=qwen-plus,gemini-3-pro,gemini-3-flash-preview,gpt-5.1

# When you want to use PWA
VITE_GLOB_APP_PWA=false
